DISCORD_BOT_TOKEN=CHANGE_ME

# Database Configuration
# Leave all DB settings empty to use the default local SQLite database:
# sqlite+aiosqlite:///data/data.db
#
# Set one full SQLAlchemy URL, or leave DATABASE_URL empty for default SQLite.
#
# Examples:
# DATABASE_URL=sqlite+aiosqlite:///data/data.db
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/database
# DATABASE_URL=mysql+aiomysql://user:password@host:3306/database
DATABASE_URL=

# Twitch API Credentials (get from https://dev.twitch.tv/console/apps)
TWITCH_CLIENT_ID="your_twitch_client_id_here"
TWITCH_CLIENT_SECRET="your_twitch_client_secret_here"
