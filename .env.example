DISCORD_BOT_TOKEN=CHANGE_ME

# Database Configuration
# Provide either DATABASE_URL (recommended) OR use individual components below
DATABASE_URL=""  # Full connection URL (e.g. sqlite+aiosqlite:///data/data.db, postgresql+asyncpg://user:pass@host/db, mysql+aiomysql://user:pass@host/db)

# Individual connection components (used only if DATABASE_URL is empty)
# Use these if you need to specify connection details separately
DB_TYPE=""        # Database type: sqlite, postgresql, mysql, mariadb (leave empty for SQLite default)
DB_HOST=""
DB_PORT=""        # Default: 5432 for PostgreSQL, 3306 for MySQL/MariaDB
DB_USER=""
DB_PASSWORD=""
DB_NAME=""
DB_PATH=""        # For SQLite: relative or absolute file path (e.g. data/data.db)

# Optional: SSL/TLS settings for PostgreSQL (e.g., for Supabase, AWS RDS, etc.)
DB_SSL_MODE=""    # SSL mode for PostgreSQL: disable, allow, prefer, require, verify-ca, verify-full
